# 云服务器 Nginx 反代示例：HTTPS 终止 + 转发到本机 Next（3000）
# 使用步骤：
# 1. 将 server_name 改为你的域名；配置 ssl_certificate / ssl_certificate_key（Let's Encrypt 等）
# 2. sudo cp trip.conf.example /etc/nginx/sites-available/trip && sudo ln -s ... sites-enabled/
# 3. sudo nginx -t && sudo systemctl reload nginx

upstream trip_next {
    server 127.0.0.1:3000;
    keepalive 64;
}

server {
    listen 80;
    server_name your-domain.com;
    # 若仅用 HTTP 可保留；生产建议跳转 HTTPS
    # 可选：在 Nginx 层补 HSTS（仅 HTTPS server 块启用，勿在纯 HTTP 开启）
    # add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;

    location / {
        proxy_pass http://trip_next;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        # 读超时略大于 Next 最长响应，可按接口调整
        proxy_read_timeout 60s;
    }
}

