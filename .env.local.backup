# trip-web（Next.js）— 复制为 .env.local 后按需修改
# cp .env.example .env.local

# -----------------------------------------------------------------------------
# 浏览器端（NEXT_PUBLIC_* 会打进前端包，改后需重新 npm run dev / npm run build）
# -----------------------------------------------------------------------------

# 外置 Nest 后端时必填：登录/注册会请求 ${NEXT_PUBLIC_API_BASE_URL}/api/auth/*
# 直连后端示例：http://127.0.0.1:3000
# Nginx 同域反代示例：/api
# 留空则走 Next 内置 /api/auth/*（与 trip-backend 分离部署时请填写）
NEXT_PUBLIC_API_BASE_URL=http://121.5.24.138:3002

NEXT_PUBLIC_APP_NAME=Trip Web
NEXT_PUBLIC_SITE_URL=http://121.5.24.138:3000
NEXT_PUBLIC_APP_VERSION=0.1.0

# -----------------------------------------------------------------------------
# 服务端（仅 Node 运行时读取，不暴露给浏览器）
# -----------------------------------------------------------------------------

# 前端使用 MySQL（与后端共享）
DATABASE_URL=mysql://magus:3W.xh.com@127.0.0.1:3306/trip

# 与 trip-backend 的 AUTH_JWT_SECRET 必须一致，middleware 才能校验登录 cookie
AUTH_JWT_SECRET=3W.xh.com

# WebSocket 连接地址（指向后端 NestJS 服务）
NEXT_PUBLIC_WS_URL=http://121.5.24.138:3002

# AUTH_COOKIE_NAME=trip_auth
# AUTH_BCRYPT_SALT_ROUNDS=12
AUTH_COOKIE_SECURE=false

# CORS 配置（与后端保持一致）
CORS_ORIGIN=http://121.5.24.138:3001,http://127.0.0.1:3000,http://127.0.0.1:3001,http://localhost:3000,http://localhost:3001,http://localhost:3002
