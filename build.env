# 复制为 .env.production 或部署平台环境变量中填写
# 前端可读的公开变量必须以 NEXT_PUBLIC_ 开头

# 后端 API 根地址（浏览器直接请求时使用，需 CORS 允许当前站点）
# 例：https://api.example.com
NEXT_PUBLIC_API_BASE_URL=

# 应用展示名称（可选）
NEXT_PUBLIC_APP_NAME=Trip Web

# 站点绝对地址（用于 metadata、sitemap、robots；生产务必改为 https 域名）
# 例：https://www.example.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Node 生产环境（Docker / PM2 一般已设置）
# NODE_ENV=production

# ==== 认证 & 数据库（后端运行时环境变量）====
# 使用外部 Postgres 的连接串（Drizzle/pg 会用到）
DATABASE_URL=

# JWT 签名密钥（用于 /api/auth/* 的登录态）
AUTH_JWT_SECRET=

# httpOnly cookie 名称（默认：trip_auth）
AUTH_COOKIE_NAME=trip_auth

# cookie 是否要求 HTTPS（Secure 标志）
# - 没配置 nginx/https 时建议设为 false，避免 HTTP 下 cookie 不回传
# - 配置 HTTPS 后可设为 true（默认：production 时自动开启）
AUTH_COOKIE_SECURE=

# bcrypt cost factor（>=10 推荐）
AUTH_BCRYPT_SALT_ROUNDS=12

# 端口（next start / standalone 默认 3000；Docker 内与 EXPOSE 一致即可）
# PORT=3000